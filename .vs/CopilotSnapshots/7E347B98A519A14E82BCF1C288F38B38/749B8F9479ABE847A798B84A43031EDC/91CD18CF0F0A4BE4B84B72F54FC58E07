    private IQueryable<Item> ApplyItemScope(IQueryable<Item> query, int currentUserId, string currentUserRole, User? currentUser)
    {
        if (currentUserRole == "USER")
        {
            return query.Where(i => i.CreatedById == currentUserId || i.Members.Any(m => m.UserId == currentUserId) || i.Assignees.Any(a => a.UserId == currentUserId));
        }

        if (currentUserRole == "ADMIN")
        {
            return query.Where(i => i.Importance == "SECRET"
                ? i.CreatedById == currentUserId || i.Members.Any(m => m.UserId == currentUserId) || i.Assignees.Any(a => a.UserId == currentUserId)
                : true);
        }

        if (currentUserRole == "MANAGER")
        {
            return query.Where(i => i.Importance == "SECRET"
                ? i.CreatedById == currentUserId || i.Members.Any(m => m.UserId == currentUserId) || i.Assignees.Any(a => a.UserId == currentUserId)
                : IsItemInManagerScope(i, currentUserId, currentUser));
        }

        return query.Where(i => i.CreatedById == currentUserId || i.Members.Any(m => m.UserId == currentUserId) || i.Assignees.Any(a => a.UserId == currentUserId));
    }

    private IQueryable<Item> ApplyOrganizationFilters(IQueryable<Item> query, string currentUserRole, User? currentUser, int? agencyId, int? departmentId, int? sectionId)
    {
        if (agencyId.HasValue) query = query.Where(i => i.Department.AgencyId == agencyId.Value);
        if (departmentId.HasValue) query = query.Where(i => i.DepartmentId == departmentId.Value);
        if (sectionId.HasValue)
            query = query.Where(i => i.CreatedBy.SectionId == sectionId.Value || i.Members.Any(m => m.User.SectionId == sectionId.Value) || i.Assignees.Any(a => a.User.SectionId == sectionId.Value));

        if (currentUserRole == "MANAGER" && currentUser != null)
        {
            if (currentUser.SectionId.HasValue)
                query = query.Where(i => i.CreatedBy.SectionId == currentUser.SectionId.Value || i.Members.Any(m => m.User.SectionId == currentUser.SectionId.Value) || i.Assignees.Any(a => a.User.SectionId == currentUser.SectionId.Value));
            else if (currentUser.DepartmentId.HasValue)
                query = query.Where(i => i.DepartmentId == currentUser.DepartmentId.Value);
            else if (currentUser.AgencyId.HasValue)
                query = query.Where(i => i.Department.AgencyId == currentUser.AgencyId.Value);
        }
        return query;
    }

    private static bool IsItemInManagerScope(Item item, int currentUserId, User? currentUser)
    {
        if (currentUser == null) return false;
        if (currentUser.SectionId.HasValue)
        {
            return item.CreatedById == currentUserId
                || item.CreatedBy?.SectionId == currentUser.SectionId.Value
                || item.Members.Any(m => m.User?.SectionId == currentUser.SectionId.Value)
                || item.Assignees.Any(a => a.User?.SectionId == currentUser.SectionId.Value);
        }
        if (currentUser.DepartmentId.HasValue) return item.DepartmentId == currentUser.DepartmentId.Value;
        if (currentUser.AgencyId.HasValue) return item.Department?.AgencyId == currentUser.AgencyId.Value;
        return false;
    }

    private void EnsureCanAccess(Item item, int currentUserId, string currentUserRole, User? currentUser)
    {
        var isParticipant = item.CreatedById == currentUserId || item.Members.Any(m => m.UserId == currentUserId) || item.Assignees.Any(a => a.UserId == currentUserId);
        var allowed = string.Equals(item.Importance, "SECRET", StringComparison.OrdinalIgnoreCase)
            ? isParticipant
            : currentUserRole == "ADMIN" || (currentUserRole == "MANAGER" ? IsItemInManagerScope(item, currentUserId, currentUser) : isParticipant);
        if (!allowed)
            throw new ApiException(StatusCodes.Status403Forbidden, "غير مصرح", null);
    }

    private void EnsureCanManage(Item item, int currentUserId, string currentUserRole, User? currentUser)
    {
        var allowed = string.Equals(item.Importance, "SECRET", StringComparison.OrdinalIgnoreCase)
            ? item.CreatedById == currentUserId
            : currentUserRole == "ADMIN" || (currentUserRole == "MANAGER" ? IsItemInManagerScope(item, currentUserId, currentUser) : item.CreatedById == currentUserId);
        if (!allowed)
            throw new ApiException(StatusCodes.Status403Forbidden, "غير مصرح", null);
    }

    private static void ValidateCreateUpdateDto(CreateItemDto? dto)
    {
        if (dto == null)
            throw new ApiException(StatusCodes.Status400BadRequest, "بيانات غير صالحة", new { errors = new[] { "بيانات العنصر غير صحيحة" } });
        if (dto.Type != "TASK" && dto.Type != "COMMITTEE")
            throw new ApiException(StatusCodes.Status400BadRequest, "بيانات غير صالحة", new { errors = new[] { "نوع العنصر غير صالح" } });
        if (string.IsNullOrWhiteSpace(dto.Title))
            throw new ApiException(StatusCodes.Status400BadRequest, "بيانات غير صالحة", new { errors = new[] { "عنوان العنصر مطلوب" } });
        if (dto.Importance != "NORMAL" && dto.Importance != "SECRET")
            throw new ApiException(StatusCodes.Status400BadRequest, "بيانات غير صالحة", new { errors = new[] { "قيمة السرية غير صحيحة" } });
        if (dto.DueDate == default)
            throw new ApiException(StatusCodes.Status400BadRequest, "بيانات غير صالحة", new { errors = new[] { "تاريخ الاستحقاق مطلوب" } });
        if (dto.Type == "COMMITTEE" && dto.CommitteeType != "INTERNAL" && dto.CommitteeType != "EXTERNAL")
            throw new ApiException(StatusCodes.Status400BadRequest, "بيانات غير صالحة", new { errors = new[] { "نوع اللجنة غير صالح" } });
    }

    private async Task<(List<int> MemberIds, List<int> AssigneeIds)> ResolveParticipantsAsync(IEnumerable<int>? memberIds, IEnumerable<string>? memberNationalIds, IEnumerable<int>? assigneeIds, IEnumerable<string>? assigneeNationalIds, int departmentId, int requiredCreatorId, bool requireCommitteeMember, CancellationToken cancellationToken)
    {
        var memberResult = await ResolveUserIdsAsync(memberIds, memberNationalIds, departmentId, "الأعضاء", cancellationToken);
        var assigneeResult = await ResolveUserIdsAsync(assigneeIds, assigneeNationalIds, departmentId, "المكلّفين", cancellationToken);
        var finalMembers = NormalizeUserIds(memberResult, requiredCreatorId);
        var finalAssignees = NormalizeUserIds(assigneeResult);
        if (requireCommitteeMember && memberResult.Count == 0)
            throw new ApiException(StatusCodes.Status400BadRequest, "بيانات غير صالحة", new { errors = new[] { "يجب تحديد عضو واحد على الأقل للجنة" } });
        return (finalMembers, finalAssignees);
    }

    private async Task<List<int>> ResolveUserIdsAsync(IEnumerable<int>? directIds, IEnumerable<string>? nationalIds, int departmentId, string label, CancellationToken cancellationToken)
    {
        var normalizedIds = NormalizeUserIds(directIds);
        var normalizedNationalIds = (nationalIds ?? Enumerable.Empty<string>())
            .Select(id => id?.Trim())
            .Where(id => !string.IsNullOrWhiteSpace(id))
            .Distinct()
            .ToList()!;

        foreach (var nationalId in normalizedNationalIds)
            if (!System.Text.RegularExpressions.Regex.IsMatch(nationalId!, @"^\d{10}$"))
                throw new ApiException(StatusCodes.Status400BadRequest, "بيانات غير صالحة", new { errors = new[] { $"كل {label} المضافين عبر الهوية يجب أن تكون هوياتهم 10 أرقام" } });

        if (normalizedNationalIds.Count > 0)
        {
            var usersByNationalId = await _context.Users
                .Where(u => normalizedNationalIds.Contains(u.NationalId))
                .Select(u => new { u.Id, u.NationalId, u.DepartmentId })
                .ToListAsync(cancellationToken);

            var missingNationalIds = normalizedNationalIds.Except(usersByNationalId.Select(u => u.NationalId)).ToList();
            if (missingNationalIds.Count > 0)
                throw new ApiException(StatusCodes.Status400BadRequest, "بيانات غير صالحة", new { errors = new[] { $"بعض أرقام الهوية غير مسجلة في النظام: {string.Join("، ", missingNationalIds)}" } });
            normalizedIds.AddRange(usersByNationalId.Select(u => u.Id));
        }

        normalizedIds = normalizedIds.Distinct().ToList();
        if (normalizedIds.Count == 0) return normalizedIds;

        var users = await _context.Users.Where(u => normalizedIds.Contains(u.Id)).Select(u => new { u.Id, u.DepartmentId }).ToListAsync(cancellationToken);
        var missingIds = normalizedIds.Except(users.Select(u => u.Id)).ToList();
        if (missingIds.Count > 0)
            throw new ApiException(StatusCodes.Status400BadRequest, "بيانات غير صالحة", new { errors = new[] { $"بعض {label} المحددين غير موجودين في النظام" } });

        var usersOutsideDepartment = users.Where(u => u.DepartmentId != departmentId).Select(u => u.Id).ToList();
        if (usersOutsideDepartment.Count > 0)
            throw new ApiException(StatusCodes.Status400BadRequest, "بيانات غير صالحة", new { errors = new[] { $"لا يمكن اختيار {label} من إدارة مختلفة" } });

        return normalizedIds;
    }

    private static IEnumerable<int> GetParticipantIds(Item item) => item.Members.Select(m => m.UserId).Concat(item.Assignees.Select(a => a.UserId)).Append(item.CreatedById).Where(id => id > 0).Distinct();

