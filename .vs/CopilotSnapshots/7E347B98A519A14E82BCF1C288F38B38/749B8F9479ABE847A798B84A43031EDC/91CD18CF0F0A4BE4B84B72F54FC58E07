    private static List<int> NormalizeUserIds(IEnumerable<int>? ids, params int[] requiredIds)
        => (ids ?? Enumerable.Empty<int>()).Concat(requiredIds).Where(id => id > 0).Distinct().ToList();

    private static ApiException NotFound() => new(StatusCodes.Status404NotFound, "العنصر غير موجود", null);
